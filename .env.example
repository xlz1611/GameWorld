# 数据库配置 (Neon PostgreSQL)
DATABASE_URL="postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# 应用配置
NEXT_PUBLIC_APP_NAME="GameHub"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# API 配置
API_RATE_LIMIT_MAX=100
API_RATE_LIMIT_WINDOW=900000

# 安全配置
JWT_SECRET="change-this-to-a-random-secret-string"
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true

# Vercel Blob 存储 (自动在 Vercel 上设置，本地开发需手动设置)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# 图片优化配置
NEXT_PUBLIC_IMAGE_QUALITY=80
NEXT_PUBLIC_IMAGE_SIZES="640,750,828,1080,1200,1920,2048,3840"

# 缓存配置
CACHE_TTL=300
CACHE_MAX_SIZE=100

# 上传配置
MAX_FILE_SIZE=104857600
ALLOWED_FILE_TYPES=".apk,.zip"

# 管理员配置
ADMIN_EMAIL="admin@gamehub.com"

# 第三方服务（可选）
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=""
# NEXT_PUBLIC_SENTRY_DSN=""
